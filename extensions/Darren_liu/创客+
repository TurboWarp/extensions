var compiledCode = [];
var isValid = false;

function log(msg, type) {
  var output = document.getElementById('output');
  var timestamp = new Date().toLocaleTimeString();
  var colorClass = type || 'info';
  output.innerHTML += '<span class="' + colorClass + '">[' + timestamp + ']</span> ' + msg + '<br>';
  output.scrollTop = output.scrollHeight;
}

function compileCode() {
  var code = document.getElementById('codeEditor').value;
  var runBtn = document.querySelector('.run');

  compiledCode = [];
  isValid = false;

  document.getElementById('output').innerHTML = '';
  log('=== Compilation Started ===', 'info');

  var lines = code.split('\n');
  var errors = [];
  var warnings = [];

  for (var i = 0; i < lines.length; i++) {
    var line = lines[i].trim();
    var lineNum = i + 1;

    if (line === '' || line.startsWith('//')) continue;

    var cleanLine = line.replace(/;/g, '').trim();
    if (cleanLine === '') continue;

    var match = cleanLine.match(/^(\w+)\s*\((.*)\)$/);
    if (!match) {
      errors.push('Line ' + lineNum + ': Invalid syntax - "' + line + '"');
      continue;
    }

    var cmd = match[1];
    var args = match[2].split(',').map(function(a) { return a.trim(); });

    var validCommands = ['digitalWrite', 'digitalRead', 'analogRead', 'analogWrite', 'pinMode', 'servoWrite', 'delay'];

    if (validCommands.indexOf(cmd) === -1) {
      errors.push('Line ' + lineNum + ': Unknown command - "' + cmd + '"');
      continue;
    }

    switch(cmd) {
      case 'digitalWrite':
        if (args.length !== 2) {
          errors.push('Line ' + lineNum + ': digitalWrite requires 2 arguments (pin, HIGH/LOW)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else if (args[1] !== 'HIGH' && args[1] !== 'LOW') {
          errors.push('Line ' + lineNum + ': Value must be HIGH or LOW - "' + args[1] + '"');
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'digitalRead':
        if (args.length !== 1) {
          errors.push('Line ' + lineNum + ': digitalRead requires 1 argument (pin)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'analogRead':
        if (args.length !== 1) {
          errors.push('Line ' + lineNum + ': analogRead requires 1 argument (pin)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'analogWrite':
        if (args.length !== 2) {
          errors.push('Line ' + lineNum + ': analogWrite requires 2 arguments (pin, value)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else if (!/^\d+$/.test(args[1])) {
          errors.push('Line ' + lineNum + ': Value must be a number (0-255) - "' + args[1] + '"');
        } else if (parseInt(args[1]) < 0 || parseInt(args[1]) > 255) {
          warnings.push('Line ' + lineNum + ': Value out of range (0-255) - will be clamped');
          compiledCode.push(cleanLine);
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'pinMode':
        if (args.length !== 2) {
          errors.push('Line ' + lineNum + ': pinMode requires 2 arguments (pin, mode)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else if (args[1] !== 'INPUT' && args[1] !== 'OUTPUT' && args[1] !== 'INPUT_PULLUP' && args[1] !== 'INPUT_PULLDOWN') {
          errors.push('Line ' + lineNum + ': Mode must be INPUT/OUTPUT/INPUT_PULLUP/INPUT_PULLDOWN - "' + args[1] + '"');
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'servoWrite':
        if (args.length !== 2) {
          errors.push('Line ' + lineNum + ': servoWrite requires 2 arguments (pin, angle)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Pin must be a number - "' + args[0] + '"');
        } else if (!/^\d+$/.test(args[1])) {
          errors.push('Line ' + lineNum + ': Angle must be a number (0-180) - "' + args[1] + '"');
        } else if (parseInt(args[1]) < 0 || parseInt(args[1]) > 180) {
          warnings.push('Line ' + lineNum + ': Angle out of range (0-180) - will be clamped');
          compiledCode.push(cleanLine);
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      case 'delay':
        if (args.length !== 1) {
          errors.push('Line ' + lineNum + ': delay requires 1 argument (milliseconds)');
        } else if (!/^\d+$/.test(args[0])) {
          errors.push('Line ' + lineNum + ': Delay must be a number - "' + args[0] + '"');
        } else {
          compiledCode.push(cleanLine);
        }
        break;
      default:
        compiledCode.push(cleanLine);
    }
  }

  warnings.forEach(function(w) { log(w, 'info'); });
  errors.forEach(function(e) { log(e, 'error'); });

  if (errors.length === 0) {
    isValid = true;
    runBtn.disabled = false;
    log('=== Compilation Successful! ===', 'success');
    log('Compiled ' + compiledCode.length + ' command(s)', 'success');
    log('Ready to run on device.', 'success');
  } else {
    isValid = false;
    runBtn.disabled = true;
    log('=== Compilation Failed with ' + errors.length + ' error(s) ===', 'error');
  }
}

function runCode() {
  if (!isValid) {
    log('Please compile first!', 'error');
    return;
  }

  var code = compiledCode.join('\n');
  window.opener.postMessage({ type: 'runCode', code: code }, '*');
  log('Code sent to device!', 'success');
}

