  var img = document.getElementById('previewImage');
  img.src = url;
  img.style.display = 'block';

  img.onload = function() {
    var canvas = document.createElement('canvas');
    var ctx = canvas.getContext('2d');
    canvas.width = 5;
    canvas.height = 5;
    ctx.drawImage(img, 0, 0, 5, 5);

    for (var row = 0; row < 5; row++) {
      for (var col = 0; col < 5; col++) {
        var pixel = ctx.getImageData(col, row, 1, 1).data;
        grid[row][col] = { r: pixel[0], g: pixel[1], b: pixel[2] };
        var cell = document.querySelector('.grid-cell[data-row="' + row + '"][data-col="' + col + '"]');
        cell.style.backgroundColor = rgbToHex(pixel[0], pixel[1], pixel[2]);
      }
    }
